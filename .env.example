REDIS_HOST=localhost
REDIS_PORT=16379
REDIS_QUEUE=fintrack_queue

DATABASE_URL=postgresql://user:password@db:5432/fintrack

LLM_BASE_URL=http://your-desktop-ip:11434/v1
OPENAI_API_KEY=not-needed
LLM_MODEL=deepseek-chat
EMBEDDING_MODEL=all-minilm

GMAIL_SEARCH_QUERY="from:notificacion_pa@pa.bac.net subject:Transaccion -label:fintrack_processed"
GMAIL_LABEL_DONE=fintrack_processed
GMAIL_POLL_INTERVAL=300
GMAIL_TOKEN_PATH=/home/fintrack/app/token.json
GMAIL_CREDENTIALS_PATH=/home/fintrack/app/credentials.json
