generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model Account {
  id          Int      @id @default(autoincrement())
  name        String
  type        String
  subtype     String?
  currency    String   @default("USD")
  institution String?
  color       String   @default("#3b82f6")
  network     String?  // "visa", "mastercard", "amex", etc.
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  transactions Transaction[]
  balances     Balance[]
  positions    Position[]

  @@map("accounts")
}

model Balance {
  id        Int      @id @default(autoincrement())
  accountId Int
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  amount    Float
  date      DateTime @default(now())

  @@index([accountId, date])
  @@map("balances")
}

model Position {
  id        Int     @id @default(autoincrement())
  accountId Int
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  ticker    String
  shares    Float

  @@unique([accountId, ticker])
  @@map("positions")
}

model Category {
  id          Int            @id @default(autoincrement())
  name        String         @unique
  color       String         @default("#10b981")
  merchants   Merchant[]
  transactions Transaction[]
}

model Merchant {
  id         Int    @id @default(autoincrement())
  name       String
  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id])

  aliases      MerchantAlias[]
  transactions Transaction[]

  @@index([name])
}

model MerchantAlias {
  id         Int      @id @default(autoincrement())
  merchantId Int
  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  rawName    String   @unique

  @@map("merchant_aliases")
  @@index([rawName])
}

model Income {
  id         Int      @id @default(autoincrement())
  amount     Float
  source     String
  category   String
  incomeDate DateTime @map("income_date")
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("income")
}

model Transaction {
  id              String    @id
  merchant        String
  merchantId      Int?
  merchantRel     Merchant? @relation(fields: [merchantId], references: [id])
  amount          Float
  currency        String    @default("USD")
  categoryId      Int?
  category        Category? @relation(fields: [categoryId], references: [id])
  categoryName    String?   @map("category")
  bank            String?
  transactionType String?   @map("transaction_type")
  transactionDate DateTime? @map("transaction_date")
  accountId       Int?
  account         Account?  @relation(fields: [accountId], references: [id])
  processedAt     DateTime  @default(now()) @map("processed_at")
  rawSnippet      String?   @map("raw_snippet")
  confidenceScore Float?    @map("confidence_score")
  embedding       Unsupported("vector(384)")?

  @@map("transactions")
  @@index([merchant])
  @@index([transactionDate])
  @@index([categoryId])
  @@index([merchantId])
  @@index([accountId])
}
